{
  "name": "key-service",
  "version": "2.4.0",
  "main": "index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "nest build && tsc migrations/*.ts --outDir dist --target es2020 --module commonjs --esModuleInterop --experimentalDecorators --emitDecoratorMetadata --skipLibCheck",
    "test:db:start": "docker compose -f docker/docker-compose.test.yml up -d postgres-test",
    "test:db:stop": "docker compose -f docker/docker-compose.test.yml down",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d migrations/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d migrations/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d migrations/data-source.ts",
    "test:e2e": "jest --config apps/app/test/jest-e2e.json",
    "test:e2e:watch": "jest --config apps/app/test/jest-e2e.json --watch",
    "test:e2e:coverage": "jest --config apps/app/test/jest-e2e.json --coverage",
    "test:unit": "jest --config apps/app/test/jest-unit.json",
    "test:unit:watch": "jest --config apps/app/test/jest-unit.json --watch",
    "test:unit:coverage": "jest --config apps/app/test/jest-unit.json --coverage",
    "test:unit:with-db": "npm run test:db:start && (npm run test:unit; TEST_EXIT_CODE=$?; npm run test:db:stop; exit $TEST_EXIT_CODE)",
    "test": "jest --config apps/app/test/jest-e2e.json && jest --config apps/app/test/jest-unit.json",
    "test:watch": "jest --config apps/app/test/jest-e2e.json --watch && jest --config apps/app/test/jest-unit.json --watch",
    "test:coverage": "jest --config apps/app/test/jest-e2e.json --coverage && jest --config apps/app/test/jest-unit.json --coverage",
    "start": "tsx apps/app/src/main.ts",
    "dev": "tsx --watch apps/app/src/main.ts",
    "release": "node scripts/release.js",
    "release:patch": "npm run release patch",
    "release:minor": "npm run release minor",
    "release:major": "npm run release major"
  },
  "repository": {
    "type": "git",
    "url": "git@gitlab.eecc.info:ssi/key-service.git"
  },
  "keywords": [],
  "author": "Christian Fries",
  "license": "AGPL-3.0",
  "description": "",
  "dependencies": {
    "@digitalbazaar/data-integrity": "^2.5.0",
    "@digitalbazaar/ecdsa-multikey": "^1.8.0",
    "@digitalbazaar/ecdsa-rdfc-2019-cryptosuite": "^1.3.0",
    "@digitalbazaar/ed25519-multikey": "^1.3.1",
    "@digitalbazaar/ed25519-signature-2020": "^5.4.0",
    "@digitalbazaar/ed25519-verification-key-2020": "^4.2.0",
    "@digitalbazaar/eddsa-rdfc-2022-cryptosuite": "^1.3.0",
    "@digitalbazaar/vc": "^7.3.0",
    "@eecc/rsa-multikey": "^1.0.2",
    "@eecc/rsa-rdfc-2025-cryptosuite": "^1.0.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.2",
    "@noble/curves": "^1.9.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jose": "^6.2.3",
    "jsonld-signatures": "^11.6.0",
    "node-cache": "^5.1.2",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.30",
    "uint8arrays": "^3.1.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "form-data": ">=4.0.6",
    "multer": ">=2.2.0",
    "undici": ">=6.24.0 <7.0.0",
    "js-yaml": ">=4.2.0"
  }
}
